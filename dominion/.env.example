# Dominion Environment Variables
# Copy to .env and fill in values

# PostgreSQL (Railway provides this automatically)
DATABASE_URL=postgresql://user:pass@host:5432/railway

# GitHub PAT (classic, repo scope)
GITHUB_PAT=ghp_...

# Worker identification
WORKER_ID=dominion-phase1

# Claude Max Plan Setup Tokens (for token rotation)
# Two Max Plan accounts — agent auto-switches when one hits rate limits
CLAUDE_SETUP_TOKEN_1=sk-ant-oat01-...  # ffirdani@gfxlabs.io
CLAUDE_SETUP_TOKEN_2=sk-ant-oat01-...  # faisalfirdani01@gmail.com
